<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.post.mapper.CommentMapper">

    <!-- 评论结果映射 -->
    <resultMap id="BaseResultMap" type="com.example.post.entity.Comment">
        <id column="comment_id" property="commentId" />
        <result column="post_id" property="postId" />
        <result column="user_id" property="userId" />
        <result column="content" property="content" />
        <result column="create_time" property="createTime" />
        <result column="status" property="status" />
    </resultMap>

    <!-- 分页查询帖子的评论 -->
    <select id="getCommentsByPostId" resultMap="BaseResultMap">
        SELECT comment_id, post_id, user_id, content, create_time, status
        FROM comment
        WHERE post_id = #{postId} AND status = 0
        ORDER BY create_time DESC
    </select>

    <!-- 查询用户发布的评论 -->
    <select id="getUserComments" resultMap="BaseResultMap">
        SELECT comment_id, post_id, user_id, content, create_time, status
        FROM comment
        WHERE user_id = #{userId} AND status = 0
        ORDER BY create_time DESC
    </select>

    <!-- 删除评论（软删除） -->
    <update id="deleteComment">
        UPDATE comment SET status = 1 WHERE comment_id = #{commentId}
    </update>

</mapper>
